# ─── Security ────────────────────────────────────────────────────────────────────
# Shared secret for service-to-service authentication.
# Must match AUTO_TRADE_SECRET in telegram-alert-signal .env.
# Leave empty to disable authentication (not recommended for production).
#
AUTO_TRADE_SECRET=my-internal-secret

# ─── Server ──────────────────────────────────────────────────────────────────────
PORT=9000
LOG_LEVEL=INFO

# ─── Account 1 ───────────────────────────────────────────────────────────────────
# Human-readable name for this account (used in logs)
ACCOUNT_1_NAME=Alice

# Bybit API credentials (generate at: https://www.bybit.com/app/user/api-management)
ACCOUNT_1_API_KEY=your-api-key-here
ACCOUNT_1_API_SECRET=your-api-secret-here

# true = Production (Mainnet), false = Testnet
ACCOUNT_1_PROD_ENV=false

# Comma-separated list of symbols this account will auto-trade.
# Use .P suffix for perpetual futures (matches TradingView naming):
#   BTCUSDT.P  = Bybit linear perpetual (FUTURES)
#   BTCUSDT    = Bybit spot
ACCOUNT_1_SYMBOLS=BTCUSDT.P,ETHUSDT.P

# Minimum loss per trade in USD.
# Used to back-calculate order quantity:
#   qty = min_loss_usd / |entry_price - sl_price| / leverage   (FUTURES)
#   qty = min_loss_usd / |entry_price - sl_price|              (SPOT)
ACCOUNT_1_MIN_LOSS_USD=10

# Optional: override leverage for specific symbols (overrides symbols.yaml default)
# For .P (perpetual) symbols, use the full name including .P:
# ACCOUNT_1_BTCUSDT.P_LEVERAGE=20
# ACCOUNT_1_ETHUSDT.P_LEVERAGE=5

# ─── Account 2 ───────────────────────────────────────────────────────────────────
ACCOUNT_2_NAME=Bob
ACCOUNT_2_API_KEY=your-api-key-here
ACCOUNT_2_API_SECRET=your-api-secret-here
ACCOUNT_2_PROD_ENV=false
ACCOUNT_2_SYMBOLS=BTCUSDT.P,SOLUSDT.P
ACCOUNT_2_MIN_LOSS_USD=5
# ACCOUNT_2_BTCUSDT.P_LEVERAGE=15

# ─── Account 3 (add more accounts by incrementing the number) ────────────────────
# ACCOUNT_3_NAME=Charlie
# ACCOUNT_3_API_KEY=...
# ACCOUNT_3_API_SECRET=...
# ACCOUNT_3_PROD_ENV=true
# ACCOUNT_3_SYMBOLS=XRPUSDT
# ACCOUNT_3_MIN_LOSS_USD=20
